# AI Provider Configuration
# For Gemini
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=8192
GEMINI_RATE_LIMIT_RPM=300
GEMINI_RATE_LIMIT_TPM=50000

# For Ollama (local development)
OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=ollama  # or 'gemini' for production
LLM_MODEL=llama3:latest
OLLAMA_TIMEOUT=60

# Application Settings
ENVIRONMENT=development
DEBUG=true
API_VERSION=v1
SECRET_KEY=your_super_secure_secret_key_for_development_environment_here_32_chars_minimum

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Processing Settings
MAX_FILE_SIZE=52428800  # 50MB
BATCH_SIZE_LIMIT=50
RESULT_CACHE_TTL=2592000  # 30 days
MAX_CONCURRENT_JOBS=10

# Monitoring & Analytics
ENABLE_USAGE_TRACKING=true
COST_ALERT_THRESHOLD=100.00  # USD
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Security
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ENABLED=true

# Database (if needed later)
DATABASE_URL=postgresql://user:password@localhost/tender_extract